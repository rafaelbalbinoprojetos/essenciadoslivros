# =============================================================
# Variáveis de ambiente — Essência dos Livros
# Copie este arquivo para .env.local e preencha os valores.
# NÃO suba .env.local para o GitHub (já está no .gitignore).
# =============================================================

# --- Supabase (FRONTEND, expostas no navegador) ---
# Onde achar: Supabase > Project Settings > API
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua_anon_public_key

# --- Supabase (BACKEND / serverless, NUNCA expor) ---
# Mesma URL acima. A SERVICE KEY fica em: Settings > API > service_role
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_SERVICE_KEY=sua_service_role_key_SECRETA

# --- OpenAI (assistente + transcrição) ---
OPENAI_API_KEY=sk-...
# Opcional: modelo de transcrição (padrão: gpt-4o-mini-transcribe)
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# --- Mercado Pago (pagamentos) ---
MERCADOPAGO_ACCESS_TOKEN=seu_access_token
# Opcional — URLs de retorno e webhook:
APP_ORIGIN=https://seu-dominio.com
MERCADOPAGO_SUCCESS_URL=
MERCADOPAGO_FAILURE_URL=
MERCADOPAGO_PENDING_URL=
MERCADOPAGO_WEBHOOK_URL=

# --- Front-end (opcionais) ---
VITE_API_BASE=
VITE_PRIVACY_URL=
VITE_TERMS_URL=
VITE_SUPABASE_RESET_REDIRECT=
